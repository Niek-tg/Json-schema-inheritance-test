{
  "name": "json-schema-inheritance-test",
  "version": "1.0.0",
  "description": "TypeScript project using AJV to validate JSON schemas for GitHub activity events",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": { "resolveJsonModule": true } }]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Niek-tg/Json-schema-inheritance-test.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Niek-tg/Json-schema-inheritance-test/issues"
  },
  "homepage": "https://github.com/Niek-tg/Json-schema-inheritance-test#readme",
  "dependencies": {
    "@types/node": "^25.3.5",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
